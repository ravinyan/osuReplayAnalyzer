<?xml version="1.0" encoding="utf-8" ?>

<configuration>
	<appSettings>
		<!--General stuff-->
		<add key="ShowHitMarkers" value="true" />
		<add key="ShowFrameMarkers" value="true" />
		<add key="ShowCursorPath" value="true" />
		<add key="ScreenResolution" value="1360x786" />
		<add key="BackgroundOpacity" value="5" />
		<add key="OsuStableFolderPath" value="" />
		<!--hidden option filled automatically (if needed)... osu!stable has in config file
		    option to choose separate location for Songs folder that can be outside of osu folder... pain-->
		<add key="OsuStableSongsFolderPath" value="" />
		<add key="OsuLazerFolderPath" value="" />
		<add key="OsuClient" value="osu!" />
		<add key="MusicVolume" value="10" />
		<add key="Show100OnTimeline" value="false" />
		<add key="Show50OnTimeline" value="false" />
		<add key="ShowMissOnTimeline" value="true" />
		<add key="ShowKeyOverlay" value="true" />
		<add key="AudioOffset" value="0" />
		<add key="FpsLimit" value="144" />
		<add key="DisablePlayfieldBorder" value="false" />
		<add key="IsHiddenModEnabled" value="false" />
		<add key="ShowHitMap" value="true" />
		<add key="ExternalSkinFolderPath" value="" />
		<add key="CurrentSkin" value="Komori - PeguLian II (PwV)" />
		<!--General stuff-->
		
		<!--Positions of UI element that can be moved-->
		<add key="URBarPosition" value="" />
		<add key="KeyOverlayPosition" value="" />
		<add key="HitMapPosition" value="" />
		<!--Positions of UI element that can be moved-->
		
		<!--Keybindings-->
		<add key="Open Menu" value="Escape"/>
		<add key="Pause" value="Space"/>
		<add key="Jump 1 Frame to Left" value="OemComma"/>
		<add key="Jump 1 Frame to Right" value="OemPeriod"/>
		<add key="Jump to closest past miss" value="Left"/>
		<add key="Jump to closest future miss" value="Right"/>
		<add key="Rate Change -0.25x" value="Down"/>
		<add key="Rate Change +0.25x" value="Up"/>
		<add key="Load previously loaded replay" value="R"/>
		<add key="Enable Hidden Mod" value="H"/>
		<!--Keybindings-->
	</appSettings>
</configuration>
